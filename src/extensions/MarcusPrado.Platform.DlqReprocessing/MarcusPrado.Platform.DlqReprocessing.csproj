<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Dead-letter queue management: Minimal API endpoints (list / reprocess / discard), IDlqStore, DlqReprocessingJob, OTel depth/reprocessed/discarded metrics.</Description>
    <PackageTags>dotnet;platform;dlq;dead-letter;messaging;reprocessing</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="OpenTelemetry" />
  </ItemGroup>
</Project>