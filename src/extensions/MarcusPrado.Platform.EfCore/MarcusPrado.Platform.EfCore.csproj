<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>EF Core integration: AppDbContextBase with automatic audit filling, domain event dispatch after SaveChanges, multi-tenant query filters, outbox/inbox tables, EfUnitOfWork with savepoint support, EfMigrationRunner.</Description>
    <PackageTags>dotnet;platform;efcore;entity-framework;audit;outbox;multi-tenancy</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions\MarcusPrado.Platform.Abstractions.csproj" />
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Domain\MarcusPrado.Platform.Domain.csproj" />
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.OutboxInbox\MarcusPrado.Platform.OutboxInbox.csproj" />
  </ItemGroup>
</Project>