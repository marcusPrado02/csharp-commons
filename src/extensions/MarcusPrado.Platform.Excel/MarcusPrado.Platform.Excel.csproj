<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Excel adapter: ClosedXmlExcelReader and ClosedXmlExcelWriter with styles, cell validation, and streaming support for large files.</Description>
    <PackageTags>dotnet;platform;excel;closedxml;spreadsheet</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="ClosedXML" />
    <!-- Explicit direct reference forces System.IO.Packaging to 10.0.5, fixing GHSA-f32c-w444-8ppv / GHSA-qj66-m88j-hmgj -->
    <PackageReference Include="System.IO.Packaging" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions.Documents\MarcusPrado.Platform.Abstractions.Documents.csproj" />
  </ItemGroup>
</Project>