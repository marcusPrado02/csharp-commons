<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Exception enrichment for ASP.NET Core: ExceptionFingerprinter (deterministic hash), ExceptionGrouper, DeveloperExceptionPageEnricher with full context in Development.</Description>
    <PackageTags>dotnet;platform;exceptions;enrichment;aspnetcore</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
</Project>