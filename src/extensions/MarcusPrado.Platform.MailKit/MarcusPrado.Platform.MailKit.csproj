<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Email adapter for IEmailSender via MailKit with HTML templates (Scriban/Fluid), file attachments, and SMTP retry with exponential backoff.</Description>
    <PackageTags>dotnet;platform;email;mailkit;smtp</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MailKit" />
    <!-- Explicit direct reference forces MimeKit to resolve to 4.15.1, fixing GHSA-g7hc-96xr-gvvx -->
    <PackageReference Include="MimeKit" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions.Email\MarcusPrado.Platform.Abstractions.Email.csproj" />
  </ItemGroup>
</Project>