<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Blockchain adapter: NethereumBlockchainClient, NethereumWalletManager, NethereumSmartContractClient via Nethereum 4.x.</Description>
    <PackageTags>dotnet;platform;blockchain;nethereum;ethereum;web3</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Nethereum.Web3" />
    <!-- Explicit direct reference forces Newtonsoft.Json to 13.0.3, fixing GHSA-5crp-9r3c-p9vr from transitive dep -->
    <PackageReference Include="Newtonsoft.Json" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions.Blockchain\MarcusPrado.Platform.Abstractions.Blockchain.csproj" />
  </ItemGroup>
</Project>