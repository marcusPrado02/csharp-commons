<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>OpenSearch adapter: OpenSearchSearchClient implementing ISearchClient and IIndexManager via OpenSearch.Client with cursor pagination support.</Description>
    <PackageTags>dotnet;platform;opensearch;search;indexing</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="OpenSearch.Client" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions.Search\MarcusPrado.Platform.Abstractions.Search.csproj" />
  </ItemGroup>
</Project>
