<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>PDF generation adapter: QuestPdfGenerator via QuestPDF with header/footer, pagination, and watermark support.</Description>
    <PackageTags>dotnet;platform;pdf;questpdf</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="QuestPDF" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions.Documents\MarcusPrado.Platform.Abstractions.Documents.csproj" />
  </ItemGroup>
</Project>