<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <Description>Redis adapter: ICache implementation, RedisDistributedLock (Redlock), IQuotaStore for rate limiting, IIdempotencyStore, StampedeProtectedCache (XFetch algorithm).</Description>
    <PackageTags>dotnet;platform;redis;cache;distributed-lock;rate-limiting;idempotency</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="StackExchange.Redis" />
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions\MarcusPrado.Platform.Abstractions.csproj" />
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.OutboxInbox\MarcusPrado.Platform.OutboxInbox.csproj" />
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.RateLimiting\MarcusPrado.Platform.RateLimiting.csproj" />
  </ItemGroup>
</Project>