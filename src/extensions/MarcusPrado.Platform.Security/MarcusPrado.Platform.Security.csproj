<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsAsErrors />
    <Deterministic>true</Deterministic>
    <Description>Security extensions: OidcClientService with proactive TokenCache renewal, AesGcmEncryption (AES-256-GCM), KeyRotationService, RSA/ECDSA digital signatures, PII masking, mTLS with CertificateTenantResolver, IInputSanitizer.</Description>
    <PackageTags>dotnet;platform;security;oidc;encryption;aes-gcm;signatures;pii;mtls</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Serilog" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\core\MarcusPrado.Platform.Abstractions\MarcusPrado.Platform.Abstractions.csproj" />
  </ItemGroup>
</Project>