<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>platform-api</ToolCommandName>
    <Description>API changelog CLI: ApiSurfaceExtractor (Reflection), ApiDiffEngine (breaking changes / additions), ChangelogRenderer (Markdown). CI integration exits with code 2 on breaking changes.</Description>
    <PackageTags>dotnet;platform;tooling;api-changelog;breaking-changes</PackageTags>
  </PropertyGroup>
</Project>