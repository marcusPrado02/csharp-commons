<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>platform</ToolCommandName>
    <PackageId>MarcusPrado.Platform.Cli</PackageId>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <IsPackable>true</IsPackable>
    <NoWarn>$(NoWarn);SA1516</NoWarn>
    <Description>Platform dotnet tool: scaffold api/worker/domain/command, config encrypt, catalog errors, arch validate, dlq inspect, health &lt;url&gt; commands.</Description>
    <PackageTags>dotnet;platform;cli;tooling;scaffold</PackageTags>
  </PropertyGroup>
</Project>