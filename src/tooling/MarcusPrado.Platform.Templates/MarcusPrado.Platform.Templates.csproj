<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageType>Template</PackageType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>MarcusPrado.Platform.Templates</PackageId>
    <PackageVersion>1.0.0</PackageVersion>
    <Title>MarcusPrado Platform Templates</Title>
    <Authors>Marcus Prado Silva</Authors>
    <Description>Project templates for MarcusPrado Platform services</Description>
    <IsPackable>true</IsPackable>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="content\**\*" Exclude="**\bin\**;**\obj\**" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="content\**\*" />
  </ItemGroup>
</Project>
